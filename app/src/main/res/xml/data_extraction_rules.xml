<?xml version="1.0" encoding="utf-8"?>
<!--
  Android Auto Backup (cloud) ve Device Transfer (cihazlar arası) için
  çıkarma kurallarını AÇIKÇA kapatır. WordLearn local-first; kendi ZIP
  backup özelliği var, kullanıcı verisi cihazda kalmalı.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
